rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile photos & logos — user can upload/read their own
    match /profiles/{userId}/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Service order uploads — authenticated users
    match /serviceOrders/{userId}/{fileName} {
      allow read:  if request.auth != null &&
                   (request.auth.uid == userId ||
                    get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 20 * 1024 * 1024;
    }

    // Admin uploads — bundles, materials, services
    match /bundles/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null &&
                   get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    match /materials/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null &&
                   get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    match /services/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null &&
                   get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Client files
    match /clientFiles/{userId}/{fileName} {
      allow read:  if request.auth != null &&
                   (request.auth.uid == userId ||
                    get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow write: if request.auth != null &&
                   get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Block everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
